# Copy this file to `.env` (same directory) and fill in your key.
# `.env` is git-ignored so your real key never gets committed.
#
# In the Udacity/Vocareum workspace, use the Vocareum-issued voc-... key.
# Locally, you can also use a regular OpenAI platform key (though the code
# targets the Vocareum base URL, so a Vocareum key is the intended fit).
OPENAI_API_KEY=voc-your-vocareum-key-here
